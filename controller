package com.yourcompany.gateway.util;

import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import jakarta.servlet.http.HttpServletRequest;
import org.springframework.http.HttpHeaders;
import org.springframework.web.server.ResponseStatusException;
import org.springframework.http.HttpStatus;

import java.util.Collections;
import java.util.Enumeration;
import java.util.Map;
import java.util.UUID;

public final class RouteUtils {

    public static final String CORRELATION_ID_HEADER = "X-Correlation-Id";

    private static final String ROUTE_BASE = "/route";
    private static final String DEFAULT_SCHEME = "http";
    private static final String DEFAULT_SERVICE_SUFFIX = "-svc";
    private static final int DEFAULT_SERVICE_PORT = 80;

    private static final ObjectMapper OBJECT_MAPPER = new ObjectMapper();

    private RouteUtils() {
    }

    public static String resolveRoutePrefix(HttpServletRequest request) {
        String requestUri = request.getRequestURI();

        if (!requestUri.startsWith(ROUTE_BASE + "/")) {
            throw new ResponseStatusException(
                    HttpStatus.BAD_REQUEST,
                    "Invalid route path"
            );
        }

        String pathAfterRoute = requestUri.substring(ROUTE_BASE.length());

        String[] parts = pathAfterRoute.split("/", 3);

        if (parts.length < 2 || parts[1].isBlank()) {
            throw new ResponseStatusException(
                    HttpStatus.BAD_REQUEST,
                    "Route prefix is missing"
            );
        }

        return parts[1];
    }

    public static String buildTargetUri(
            HttpServletRequest request,
            String routePrefix,
            String serviceMapperJson
    ) {
        Map<String, String> serviceMapper = parseServiceMapper(serviceMapperJson);

        String targetBaseUri = serviceMapper.get(routePrefix);

        if (targetBaseUri == null || targetBaseUri.isBlank()) {
            targetBaseUri = DEFAULT_SCHEME + "://"
                    + routePrefix
                    + DEFAULT_SERVICE_SUFFIX
                    + ":"
                    + DEFAULT_SERVICE_PORT;
        }

        targetBaseUri = removeTrailingSlash(targetBaseUri);

        String pathAfterRoute = request.getRequestURI().substring(ROUTE_BASE.length());

        String targetUri = targetBaseUri + pathAfterRoute;

        if (request.getQueryString() != null && !request.getQueryString().isBlank()) {
            targetUri = targetUri + "?" + request.getQueryString();
        }

        return targetUri;
    }

    private static Map<String, String> parseServiceMapper(String serviceMapperJson) {
        try {
            if (serviceMapperJson == null || serviceMapperJson.isBlank()) {
                return Collections.emptyMap();
            }

            return OBJECT_MAPPER.readValue(
                    serviceMapperJson,
                    new TypeReference<Map<String, String>>() {}
            );

        } catch (Exception ex) {
            throw new ResponseStatusException(
                    HttpStatus.INTERNAL_SERVER_ERROR,
                    "Invalid SERVICE_MAPPER configuration"
            );
        }
    }

    private static String removeTrailingSlash(String value) {
        if (value != null && value.endsWith("/")) {
            return value.substring(0, value.length() - 1);
        }

        return value;
    }

    public static HttpHeaders buildOutboundHeaders(
            HttpServletRequest request,
            String appUser,
            String correlationId,
            String token
    ) {
        HttpHeaders headers = new HttpHeaders();

        Enumeration<String> headerNames = request.getHeaderNames();

        if (headerNames != null) {
            for (String headerName : Collections.list(headerNames)) {
                if (shouldSkipRequestHeader(headerName)) {
                    continue;
                }

                headers.addAll(
                        headerName,
                        Collections.list(request.getHeaders(headerName))
                );
            }
        }

        headers.setBearerAuth(token);
        headers.set(CORRELATION_ID_HEADER, correlationId);
        headers.set("X-App-User", appUser);

        return headers;
    }

    public static HttpHeaders buildResponseHeaders(
            HttpHeaders sourceHeaders,
            String correlationId,
            String appUser,
            String routePrefix
    ) {
        HttpHeaders headers = new HttpHeaders();

        if (sourceHeaders != null) {
            sourceHeaders.forEach((headerName, values) -> {
                if (!shouldSkipResponseHeader(headerName)) {
                    headers.put(headerName, values);
                }
            });
        }

        headers.set(CORRELATION_ID_HEADER, correlationId);
        headers.set("X-App-User", appUser);
        headers.set("X-Route-Prefix", routePrefix);

        return headers;
    }

    public static boolean hasBody(byte[] body) {
        return body != null && body.length > 0;
    }

    public static String resolveCorrelationId(HttpServletRequest request) {
        String correlationId = request.getHeader(CORRELATION_ID_HEADER);

        if (correlationId == null || correlationId.isBlank()) {
            return UUID.randomUUID().toString();
        }

        return correlationId;
    }

    public static String getClientIpAddress(HttpServletRequest request) {
        String forwardedFor = request.getHeader("X-Forwarded-For");

        if (forwardedFor != null && !forwardedFor.isBlank()) {
            return forwardedFor.split(",")[0].trim();
        }

        String realIp = request.getHeader("X-Real-IP");

        if (realIp != null && !realIp.isBlank()) {
            return realIp;
        }

        return request.getRemoteAddr();
    }

    private static boolean shouldSkipRequestHeader(String headerName) {
        return headerName.equalsIgnoreCase(HttpHeaders.HOST)
                || headerName.equalsIgnoreCase(HttpHeaders.CONTENT_LENGTH)
                || headerName.equalsIgnoreCase(HttpHeaders.AUTHORIZATION)
                || headerName.equalsIgnoreCase(HttpHeaders.CONNECTION);
    }

    private static boolean shouldSkipResponseHeader(String headerName) {
        return headerName.equalsIgnoreCase(HttpHeaders.TRANSFER_ENCODING)
                || headerName.equalsIgnoreCase(HttpHeaders.CONTENT_LENGTH)
                || headerName.equalsIgnoreCase(HttpHeaders.CONNECTION);
    }
}

