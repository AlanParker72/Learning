@Service
public class RouteServiceImpl implements RouteService {

    private static final Logger log = LoggerFactory.getLogger(RouteServiceImpl.class);

    private final RestClient restClient;
    private final JwtService jwtService;

    @Value("${SERVICE_MAPPER:{}}")
    private String serviceMapperJson;

    public RouteServiceImpl(RestClient restClient, JwtService jwtService) {
        this.restClient = restClient;
        this.jwtService = jwtService;
    }

    @Override
    public ResponseEntity<byte[]> forward(HttpServletRequest request, byte[] body) {

        String routePrefix = RouteUtils.resolveRoutePrefix(request);

        String targetUri = RouteUtils.buildTargetUri(
                request,
                routePrefix,
                serviceMapperJson
        );

        Authentication authentication =
                SecurityContextHolder.getContext().getAuthentication();

        String correlationId = RouteUtils.resolveCorrelationId(request);

        String appUser = authentication != null
                ? authentication.getName()
                : "anonymous";

        String ipAddress = RouteUtils.getClientIpAddress(request);

        HttpSession session = request.getSession(false);

        HttpMethod method = HttpMethod.valueOf(request.getMethod());

        String token = jwtService.createToken(
                authentication,
                session,
                ipAddress
        );

        HttpHeaders outboundHeaders = RouteUtils.buildOutboundHeaders(
                request,
                appUser,
                correlationId,
                token
        );

        outboundHeaders.setBearerAuth(token);
        outboundHeaders.set(RouteUtils.CORRELATION_ID_HEADER, correlationId);

        try {
            log.info(
                    "Forwarding request => method={} sourceUri={} targetUri={} routePrefix={} correlationId={} user={}",
                    method,
                    request.getRequestURI(),
                    targetUri,
                    routePrefix,
                    correlationId,
                    appUser
            );

            ResponseEntity<byte[]> response = executeRoute(
                    method,
                    targetUri,
                    outboundHeaders,
                    body
            );

            log.info(
                    "Route success => status={} routePrefix={} correlationId={} user={}",
                    response.getStatusCode(),
                    routePrefix,
                    correlationId,
                    appUser
            );

            return buildSuccessResponse(
                    response,
                    correlationId,
                    appUser,
                    routePrefix
            );

        } catch (RestClientResponseException ex) {
            log.warn(
                    "Route returned error => status={} routePrefix={} targetUri={} correlationId={} user={}",
                    ex.getStatusCode().value(),
                    routePrefix,
                    targetUri,
                    correlationId,
                    appUser
            );

            return buildErrorResponse(
                    ex,
                    correlationId,
                    appUser,
                    routePrefix
            );

        } catch (Exception ex) {
            log.error(
                    "Error during route request => routePrefix={} targetUri={} correlationId={} user={}",
                    routePrefix,
                    targetUri,
                    correlationId,
                    appUser,
                    ex
            );

            throw new BadRequestException(
                    "Route target is unavailable for route " + routePrefix
            );
        }
    }

    private ResponseEntity<byte[]> executeRoute(
            HttpMethod method,
            String targetUri,
            HttpHeaders outboundHeaders,
            byte[] body
    ) {
        RestClient.RequestBodySpec requestSpec = restClient
                .method(method)
                .uri(URI.create(targetUri))
                .headers(headers -> headers.addAll(outboundHeaders));

        if (RouteUtils.hasBody(body)) {
            requestSpec.body(body);
        }

        return requestSpec
                .retrieve()
                .toEntity(byte[].class);
    }

    private ResponseEntity<byte[]> buildSuccessResponse(
            ResponseEntity<byte[]> response,
            String correlationId,
            String appUser,
            String routePrefix
    ) {
        HttpHeaders responseHeaders = RouteUtils.buildResponseHeaders(
                response.getHeaders(),
                correlationId,
                appUser,
                routePrefix
        );

        return new ResponseEntity<>(
                response.getBody(),
                responseHeaders,
                response.getStatusCode()
        );
    }

    private ResponseEntity<byte[]> buildErrorResponse(
            RestClientResponseException ex,
            String correlationId,
            String appUser,
            String routePrefix
    ) {
        HttpHeaders responseHeaders = RouteUtils.buildResponseHeaders(
                ex.getResponseHeaders(),
                correlationId,
                appUser,
                routePrefix
        );

        return new ResponseEntity<>(
                ex.getResponseBodyAsByteArray(),
                responseHeaders,
                ex.getStatusCode()
        );
    }
}

